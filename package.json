{
  "name": "g-ai-desktop",
  "version": "0.10.0",
  "productName": "G-AI Desktop",
  "copyright": "Copyright © 2026 g-ai",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "csvtojson": "^2.0.10",
    "mammoth": "^1.8.0",
    "pdf-lib": "^1.17.1"
  },
  "build": {
    "appId": "com.g-ai.desktop",
    "productName": "G-AI Desktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}